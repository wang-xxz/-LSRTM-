prog2 = Program(Split('/home/zxc/rsf/lsrtm/Mlsprtm2d.c /home/zxc/rsf/lsrtm/prtm2d.c\
			 /home/zxc/madagascar-3.1.1/madagascar-3.1.1/user/pyang/pblas.c' ), PROGSUFFIX='.x',
