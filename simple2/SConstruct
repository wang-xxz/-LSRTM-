prog2 = Program(Split('/home/zxd/rsf/lsrtm/Mlsprtm2d.c /home/zxd/rsf/lsrtm/prtm2d.c\
			 /home/zxd/rsf/madagascar-3.0/user/pyang/pblas.c' ), PROGSUFFIX='.x',
