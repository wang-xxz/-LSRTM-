exe2 = str(prog2[0])

dip0 = 'vel-dip'
Flow(dip0, 'vel-ext-smo',
     'fdip verb=n rect1=3 rect2=3')

Result(dip0, igrey2d('color=j') + winpar)
Flow(['lsimage','imgrtm'],
     ['shots', 'vel-ext-smo',dip0,exe2],
    '''
      ${SOURCES[3].abspath} vel=${SOURCES[1]} dip=${SOURCES[2]}  verb=y niter=1 testadj=0
    ''')
#Plot('lsimage','grey title="LSRTM" ')
#Result('all','lsimage','SideBySideAniso')
Result('lsimage','window %s | ' % winpar+igrey2d('color=i wantscalebar=y pclip=99'))
Result('imglsm1','window %s | ' % winpar+igrey2d('color=i wantscalebar=y pclip=99'))
Result('imglsm5','window %s | ' % winpar+igrey2d('color=i wantscalebar=y pclip=99'))
Result('imglsm10','window %s | ' % winpar+igrey2d('color=i wantscalebar=y pclip=99'))
Result('imglsm20','window %s | ' % winpar+igrey2d('color=i wantscalebar=y pclip=99'))

Flow('imglap', 'lsimage',
     'laplac adj=n')
Result('imglap','window %s | ' % winpar+igrey2d('color=i wantscalebar=y pclip=99'))

dip0 = 'vel-dip'
Flow(dip0, 'vel-ext-smo',
     'fdip verb=n rect1=3 rect2=3')
Result(dip0, igrey2d('color=j') + winpar)
Flow(['lsimage10'],
     ['lsimage', dip0],
    '''
      pwsmooth ${SOURCES[3].abspath} dip=${SOURCES[1]}  verb=n ns=10 adj=n eps=0.01 order=10
    ''')
Result('lsimage10','window %s | ' % winpar+igrey2d('color=i wantscalebar=y pclip=99'))


