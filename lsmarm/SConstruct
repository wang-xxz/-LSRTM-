Flow(['marms'],
     ['marm-img', dip0],
    '''
      pwsmooth ${SOURCES[3].abspath} dip=${SOURCES[1]}  verb=n ns=2 adj=n eps=0.01 order=10
    ''')

Result('marms','window %s | ' % winpar+igrey2d('color=i wantscalebar=y pclip=99'))

Result('marms-zoom1', 'marms',
       'window %s | ' % zoompar1 + igrey2d('color=i scalebar=n pclip=99'))

Result('marms-zoom2', 'marms',
       'window %s | ' % zoompar2 + igrey2d('color=i scalebar=n pclip=99'))

End()

